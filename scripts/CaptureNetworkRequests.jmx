// Write filtered request URLs to CSV
def csvFile = new File(&quot;C:/Network_Requests/network_requests_rsc.csv&quot;)
csvFile.withWriter(&apos;UTF-8&apos;) { writer -&gt;
    writer.writeLine(&quot;URL&quot;)
    requestUrls.each { writer.writeLine(it) }
}

driver.quit()
