        <com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler guiclass="com.googlecode.jmeter.plugins.webdriver.sampler.gui.WebDriverSamplerGui" testclass="com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler" testname="jp@gc - WebDriver Sampler - No duplicates" enabled="false">
          <stringProp name="WebDriverSampler.script">import org.openqa.selenium.chrome.ChromeDriver
import org.openqa.selenium.chrome.ChromeOptions
import org.openqa.selenium.devtools.DevTools
import org.openqa.selenium.devtools.v116.network.Network
import org.openqa.selenium.devtools.v116.network.model.Request
import org.openqa.selenium.WebDriver
import java.io.File
import java.util.Optional
import java.util.LinkedHashSet

// Get freeText parameter safely
String freeTextParam
try {
    freeTextParam = vars.get(&quot;freeText&quot;) // From JMeter variable
} catch (MissingPropertyException e) {
    freeTextParam = &quot;shirt&quot; // Default for local testing
}

ChromeOptions options = new ChromeOptions()
options.addArguments(&quot;--remote-allow-origins=*&quot;)
options.addArguments(&quot;--disable-gpu&quot;)
options.addArguments(&quot;--window-size=1920,1080&quot;)
options.addArguments(&quot;--start-maximized&quot;)

WebDriver driver = new ChromeDriver(options)

// Start DevTools session
DevTools devTools = ((ChromeDriver) driver).getDevTools()
devTools.createSession()

// Enable Network domain to capture requests
devTools.send(Network.enable(Optional.empty(), Optional.empty(), Optional.empty()))

// Use a map to store normalized key to original value for uniqueness and output
Map&lt;String, String&gt; uniqueParamPairs = [:]

// Read existing entries from CSV if file exists, to avoid duplicates across runs
def csvFile = new File(&quot;C:/Network_Requests/network_requests_freetext.csv&quot;)
if (csvFile.exists()) {
    csvFile.eachLine { line -&gt;
        if (!line.startsWith(&quot;freeText&quot;)) {  // Skip header
            def parts = line.split(&quot;,&quot;, 2)
            if (parts.length == 2) {
                String normKey = parts[0].trim().toLowerCase() + &quot;,&quot; + parts[1].trim().toLowerCase()
                uniqueParamPairs[normKey] = line.trim()  // store original line
            }
        }
    }
}

// Add listener to capture new entries during this run
devTools.addListener(Network.requestWillBeSent(), { request -&gt;
    Request req = request.getRequest()
    String url = req.getUrl()

    if (url.contains(&quot;_rsc=&quot;)) {
        String freeText = &quot;&quot;
        String rsc = &quot;&quot;

        def freeTextMatch = (url =~ /[?&amp;]freeText=([^&amp;]+)/)
        if (freeTextMatch.find()) {
            freeText = freeTextMatch.group(1)
        }

        def rscMatch = (url =~ /[?&amp;]_rsc=([^&amp;]+)/)
        if (rscMatch.find()) {
            rsc = rscMatch.group(1)
        }

        String normKey = freeText.trim().toLowerCase() + &quot;,&quot; + rsc.trim().toLowerCase()
        uniqueParamPairs[normKey] = &quot;${freeText},${rsc}&quot;  // store original values
    }
})

String username = &quot;goldtest&quot;
String password = &quot;g0ld5ive&quot;
String baseUrl = &quot;https://www.perf-selfridges.com/GB/en/cat/?freeText=${freeTextParam}&amp;srch=Y&quot;
String authenticatedUrl = &quot;https://${username}:${password}@&quot; + baseUrl.substring(8)

driver.get(authenticatedUrl)
Thread.sleep(5000)

// Write all unique entries back to the CSV file (overwrite)
csvFile.withWriter(&apos;UTF-8&apos;) { writer -&gt;
    writer.writeLine(&quot;freeText,_rsc&quot;)
    uniqueParamPairs.values().each { writer.writeLine(it) }
}

driver.quit()
</stringProp>
